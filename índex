<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cálculo de Tasa TDA - Desarrollo de Software</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideInRight { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes slideInBottom { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes zoomIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
        
        .animate-in { 
            animation-duration: 0.5s; 
            animation-fill-mode: forwards; 
        }
        .fade-in { animation-name: fadeIn; }
        .slide-in-from-right { animation-name: slideInRight; }
        .slide-in-from-bottom { animation-name: slideInBottom; }
        .zoom-in { animation-name: zoomIn; }

        /* Clase para ocultar pasos inactivos */
        .step-hidden {
            display: none !important;
        }
    </style>
</head>
<body class="min-h-screen bg-slate-50 flex flex-col font-sans text-gray-800">

    <!-- Header -->
    <header class="bg-white border-b shadow-sm py-4 px-6 md:px-12 flex justify-between items-center z-10">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Cálculo de Tasa TDA</h1>
            <p class="text-sm text-gray-500">Desarrollo de Software 2025-2</p>
        </div>
        <div id="step-indicator" class="bg-indigo-100 text-indigo-800 px-4 py-2 rounded-lg font-semibold text-sm">
            Paso 1 de 6
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col justify-center items-center p-6 md:p-12 overflow-hidden relative">
        <div class="w-full max-w-5xl mx-auto flex flex-col h-full min-h-[500px]">
            
            <!-- Step Header -->
            <div class="text-center mb-10">
                <h2 id="step-title" class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-2">Título</h2>
                <p id="step-subtitle" class="text-lg text-gray-500">Subtítulo</p>
            </div>

            <!-- Contenedor dinámico de pasos -->
            <div class="flex-1 flex items-center justify-center relative w-full">
                
                <!-- PASO 0: Introducción -->
                <div id="slide-0" class="step-content flex flex-col items-center justify-center space-y-8 animate-in fade-in zoom-in w-full">
                    <p class="text-xl text-gray-700 text-center max-w-2xl">
                        La <strong>Tasa de Deserción Anual (TDA)</strong> mide los estudiantes que abandonan el programa durante un año completo (dos semestres consecutivos). Por esto, nuestra base será el periodo <strong>t-2</strong>.
                    </p>
                    <div class="bg-indigo-50 border-2 border-indigo-200 rounded-xl p-8 shadow-sm">
                        <h3 class="text-lg font-bold text-indigo-800 mb-4 text-center">Fórmula General</h3>
                        <div class="flex items-center text-3xl font-serif text-gray-800">
                            <span>TDA<sub>t</sub></span>
                            <span class="mx-4">=</span>
                            <div class="flex flex-col items-center">
                                <span class="border-b-2 border-gray-800 px-4 pb-1">Desertores<sub>t</sub></span>
                                <span class="px-4 pt-1">Matriculados<sub>t-2</sub></span>
                            </div>
                            <span class="mx-4">×</span>
                            <span>100</span>
                        </div>
                    </div>
                    <p class="text-gray-500 italic text-sm text-center max-w-lg mt-4">
                        Analizaremos qué pasó con los estudiantes desde el periodo 2024-2 (t-2) hasta el periodo actual 2025-2 (t).
                    </p>
                </div>

                <!-- PASO 1: Población Base -->
                <div id="slide-1" class="step-content step-hidden flex flex-col items-center justify-center space-y-6 animate-in slide-in-from-right w-full">
                    <div class="bg-indigo-600 text-white p-8 rounded-full shadow-lg flex flex-col items-center justify-center w-64 h-64 border-4 border-indigo-200">
                        <i data-lucide="users" class="w-16 h-16 mb-2"></i>
                        <span class="text-5xl font-bold">1108</span>
                        <span class="text-sm mt-2 text-indigo-100 text-center">Estudiantes Matriculados<br/>en 2024-2</span>
                    </div>
                    <p class="text-xl text-gray-700 text-center max-w-xl">
                        Este es nuestro denominador (<strong>Matriculados<sub>t-2</sub></strong>). Son todos los estudiantes que estaban activos hace exactamente un año.
                    </p>
                </div>

                <!-- PASO 2: Ausentes Iniciales -->
                <div id="slide-2" class="step-content step-hidden flex flex-col items-center justify-center w-full animate-in slide-in-from-right">
                    <div class="flex flex-col md:flex-row items-center justify-center space-y-6 md:space-y-0 md:space-x-8 w-full">
                        <!-- Base -->
                        <div class="flex flex-col items-center">
                            <div class="bg-indigo-100 p-4 rounded-xl shadow border border-indigo-300 w-44 h-44 flex flex-col items-center justify-center relative">
                                <span class="absolute -top-3 bg-indigo-600 text-white text-xs px-2 py-1 rounded-full">Hace un año (t-2)</span>
                                <span class="text-4xl font-bold text-indigo-800">1108</span>
                                <span class="text-xs text-center mt-2 text-indigo-600">Matriculados 2024-2</span>
                            </div>
                        </div>
                        
                        <i data-lucide="arrow-right" class="w-8 h-8 text-gray-400 rotate-90 md:rotate-0"></i>
                        
                        <div class="flex flex-col space-y-4">
                            <!-- Continuaron -->
                            <div class="bg-teal-50 p-4 rounded-xl shadow border border-teal-200 w-56 flex items-center space-x-3 relative">
                                <span class="absolute -left-3 -top-3 bg-teal-500 text-white text-[10px] px-2 py-1 rounded-full">Siguiente semestre</span>
                                <i data-lucide="check-circle" class="w-7 h-7 text-teal-600 flex-shrink-0"></i>
                                <div>
                                    <span class="block text-2xl font-bold text-teal-800">979</span>
                                    <span class="text-xs text-teal-700 leading-tight">Se matricularon en 2025-1</span>
                                </div>
                            </div>
                            <!-- Ausentes iniciales -->
                            <div class="bg-orange-50 p-4 rounded-xl shadow border border-orange-300 w-56 flex items-center space-x-3 relative">
                                <i data-lucide="user-minus" class="w-7 h-7 text-orange-600 flex-shrink-0"></i>
                                <div>
                                    <span class="block text-2xl font-bold text-orange-800">129</span>
                                    <span class="text-xs text-orange-700 leading-tight">Ausentes en 2025-1<br/>(Posibles desertores)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-8 bg-gray-50 p-4 rounded-lg border border-gray-200 text-center max-w-xl">
                        <p class="text-lg text-gray-700">
                            A principios de este año (2025-1), perdimos el rastro de <strong class="text-orange-600">129 estudiantes</strong> (1108 - 979). <br/>Vamos a investigar qué pasó con ellos para el periodo actual (2025-2).
                        </p>
                    </div>
                </div>

                <!-- PASO 3: Depuración -->
                <div id="slide-3" class="step-content step-hidden flex flex-col items-center justify-center w-full animate-in zoom-in">
                    <div class="bg-orange-100 px-6 py-2 rounded-full mb-6 border border-orange-300 shadow-sm flex items-center gap-2">
                        <span class="text-2xl font-bold text-orange-800">129</span>
                        <span class="text-orange-700 font-medium">Posibles desertores a depurar</span>
                    </div>
                    
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 w-full max-w-5xl">
                        <!-- Reingresos -->
                        <div class="bg-white p-4 rounded-xl shadow border-t-4 border-purple-400 flex flex-col items-center text-center">
                            <i data-lucide="history" class="w-7 h-7 text-purple-500 mb-2"></i>
                            <span class="text-3xl font-bold text-gray-800">18</span>
                            <span class="text-xs font-bold text-gray-600 mt-1">Reingresos 2025-2</span>
                            <p class="text-[10px] text-gray-500 mt-1">Volvieron este semestre.</p>
                        </div>

                        <!-- Graduados -->
                        <div class="bg-white p-4 rounded-xl shadow border-t-4 border-green-400 flex flex-col items-center text-center">
                            <i data-lucide="graduation-cap" class="w-7 h-7 text-green-500 mb-2"></i>
                            <span class="text-3xl font-bold text-gray-800">23</span>
                            <span class="text-xs font-bold text-gray-600 mt-1">Graduados</span>
                            <p class="text-[10px] text-gray-500 mt-1">Se titularon con éxito.</p>
                        </div>

                        <!-- FIMA -->
                        <div class="bg-white p-4 rounded-xl shadow border-t-4 border-blue-400 flex flex-col items-center text-center">
                            <i data-lucide="book-open" class="w-7 h-7 text-blue-500 mb-2"></i>
                            <span class="text-3xl font-bold text-gray-800">7</span>
                            <span class="text-xs font-bold text-gray-600 mt-1">Finalizados (FIMA)</span>
                            <p class="text-[10px] text-gray-500 mt-1">Culminaron materias.</p>
                        </div>
                        
                        <!-- Desertores reales -->
                        <div class="bg-red-50 p-4 rounded-xl shadow-lg border-2 border-red-400 flex flex-col items-center text-center transform scale-105">
                            <i data-lucide="x-circle" class="w-7 h-7 text-red-500 mb-2"></i>
                            <span class="text-4xl font-bold text-red-600">81</span>
                            <span class="text-xs font-bold text-red-800 mt-1">Desertores Reales</span>
                            <p class="text-[10px] text-red-600 mt-1">No están ni en 2025-1 ni 2025-2.</p>
                        </div>
                    </div>
                    
                    <div class="mt-6 text-gray-600 bg-white p-3 rounded-lg shadow-sm border text-sm text-center">
                        <strong>Fórmula de depuración:</strong> 129 (Ausentes) - 18 (Reingresos) - 23 (Graduados) - 7 (FIMA) = <strong class="text-red-600">81 Desertores</strong>
                    </div>
                </div>

                <!-- PASO 4: Variables Finales -->
                <div id="slide-4" class="step-content step-hidden flex flex-col items-center justify-center space-y-8 animate-in slide-in-from-bottom w-full">
                    <div class="flex flex-col md:flex-row items-center justify-center gap-8 w-full max-w-3xl">
                        
                        <div class="flex-1 bg-red-50 rounded-xl p-6 border-2 border-red-200 text-center relative w-full shadow-md">
                            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-red-600 text-white text-xs px-4 py-1 rounded-full font-bold shadow whitespace-nowrap">
                                Numerador (Desertores<sub>t</sub>)
                            </div>
                            <span class="block text-6xl font-bold text-red-600 mt-2">81</span>
                            <span class="block text-sm text-red-800 mt-2 font-medium">Abandonaron en el último año</span>
                        </div>

                        <div class="flex-1 bg-indigo-50 rounded-xl p-6 border-2 border-indigo-300 text-center relative w-full shadow-md">
                            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-indigo-600 text-white text-xs px-4 py-1 rounded-full font-bold shadow whitespace-nowrap">
                                Denominador (Matriculados<sub>t-2</sub>)
                            </div>
                            <span class="block text-6xl font-bold text-indigo-700 mt-2">1108</span>
                            <span class="block text-sm text-indigo-800 mt-2 font-medium">Matriculados en 2024-2</span>
                        </div>

                    </div>
                </div>

                <!-- PASO 5: Cálculo Final -->
                <div id="slide-5" class="step-content step-hidden flex flex-col items-center justify-center space-y-10 animate-in zoom-in w-full">
                    <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 shadow-xl">
                        <div class="flex items-center text-4xl font-serif text-gray-800">
                            <span class="font-bold text-indigo-900">TDA</span>
                            <span class="mx-4">=</span>
                            <div class="flex flex-col items-center">
                                <span class="border-b-4 border-gray-800 px-6 pb-2 text-red-600 font-bold">81</span>
                                <span class="px-6 pt-2 text-indigo-600 font-bold">1108</span>
                            </div>
                            <span class="mx-4">×</span>
                            <span class="font-bold">100</span>
                        </div>
                    </div>

                    <i data-lucide="arrow-down" class="w-8 h-8 text-gray-400"></i>

                    <div class="bg-purple-600 text-white rounded-2xl p-6 shadow-2xl flex items-center space-x-6 transform scale-110">
                        <i data-lucide="calculator" class="w-12 h-12 text-purple-200"></i>
                        <div>
                            <span class="block text-sm text-purple-100 uppercase tracking-wider font-semibold mb-1">Resultado Final TDA</span>
                            <span class="block text-6xl font-bold">7.3%</span>
                        </div>
                    </div>

                    <p class="text-gray-600 text-center max-w-lg font-medium">
                        A lo largo de un año, el <strong>7.3%</strong> de los estudiantes del programa de Tecnología en Desarrollo de Software abandonaron definitivamente sus estudios.
                    </p>
                </div>

            </div>

        </div>
    </main>

    <!-- Footer Controls -->
    <footer class="bg-white border-t p-6">
        <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
            
            <!-- Progress Bar -->
            <div id="progress-bar-container" class="flex space-x-2 w-full md:w-auto order-2 md:order-1 justify-center">
                <!-- Se inyecta por JS -->
            </div>

            <!-- Buttons -->
            <div class="flex space-x-4 w-full md:w-auto order-1 md:order-2">
                <button
                    id="btn-prev"
                    class="flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-indigo-600"
                >
                    Anterior
                </button>
                <button
                    id="btn-next"
                    class="flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-indigo-600 text-white hover:bg-indigo-700 shadow-md"
                >
                    Siguiente
                </button>
            </div>
        </div>
    </footer>

    <!-- Logica JavaScript -->
    <script>
        // Inicializar Iconos
        lucide.createIcons();

        // Estado
        let currentStep = 0;
        
        // Datos de la presentación
        const stepsData = [
            { title: "Introducción: Cálculo de la Tasa TDA", subtitle: "Periodo 2025-2 | Programa: Tecnología en Desarrollo de Software" },
            { title: "Paso 1: Población Base Anual", subtitle: "Miramos un año atrás: Matriculados en 2024-2 (t-2)" },
            { title: "Paso 2: Ausentes Iniciales", subtitle: "Primer filtro: ¿Qué pasó en el semestre intermedio (2025-1)?" },
            { title: "Paso 3: Depuración de los 129 Ausentes", subtitle: "¿Realmente abandonaron la universidad?" },
            { title: "Paso 4: Variables Finales", subtitle: "Componentes listos para la fórmula TDA" },
            { title: "Paso 5: Cálculo Final", subtitle: "Obteniendo la Tasa de Deserción Anual (TDA)" }
        ];

        const totalSteps = stepsData.length;

        // Referencias al DOM
        const titleEl = document.getElementById('step-title');
        const subtitleEl = document.getElementById('step-subtitle');
        const indicatorEl = document.getElementById('step-indicator');
        const progressContainer = document.getElementById('progress-bar-container');
        const btnPrev = document.getElementById('btn-prev');
        const btnNext = document.getElementById('btn-next');

        function renderProgress() {
            progressContainer.innerHTML = '';
            for (let i = 0; i < totalSteps; i++) {
                const dot = document.createElement('div');
                dot.className = `h-2 rounded-full transition-all duration-300 ${
                    i === currentStep ? 'bg-indigo-600 w-12' : 
                    i < currentStep ? 'bg-indigo-200 w-8' : 'bg-gray-200 w-8'
                }`;
                progressContainer.appendChild(dot);
            }
        }

        function updateUI() {
            // Actualizar Textos
            titleEl.innerText = stepsData[currentStep].title;
            subtitleEl.innerText = stepsData[currentStep].subtitle;
            indicatorEl.innerText = `Paso ${currentStep + 1} de ${totalSteps}`;

            // Actualizar Diapositivas (Ocultar/Mostrar para re-disparar animación)
            for (let i = 0; i < totalSteps; i++) {
                const slide = document.getElementById(`slide-${i}`);
                if (i === currentStep) {
                    slide.classList.remove('step-hidden');
                    // Pequeño truco para reiniciar la animación CSS
                    slide.style.animation = 'none';
                    slide.offsetHeight; /* trigger reflow */
                    slide.style.animation = null; 
                } else {
                    slide.classList.add('step-hidden');
                }
            }

            // Actualizar Botones
            if (currentStep === 0) {
                btnPrev.disabled = true;
                btnPrev.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-gray-100 text-gray-400 cursor-not-allowed";
            } else {
                btnPrev.disabled = false;
                btnPrev.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-indigo-600 cursor-pointer";
            }

            if (currentStep === totalSteps - 1) {
                btnNext.disabled = true;
                btnNext.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-gray-100 text-gray-400 cursor-not-allowed";
                btnNext.innerText = "Siguiente";
            } else {
                btnNext.disabled = false;
                btnNext.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-indigo-600 text-white hover:bg-indigo-700 shadow-md cursor-pointer";
                btnNext.innerText = currentStep === totalSteps - 2 ? "Ver Resultado Final" : "Siguiente";
            }

            renderProgress();
        }

        // Event Listeners
        btnNext.addEventListener('click', () => {
            if (currentStep < totalSteps - 1) {
                currentStep++;
                updateUI();
            }
        });

        btnPrev.addEventListener('click', () => {
            if (currentStep > 0) {
                currentStep--;
                updateUI();
            }
        });

        // Inicialización de la vista
        updateUI();

    </script>
</body>
</html>
