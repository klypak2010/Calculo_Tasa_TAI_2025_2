<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cálculo de Tasa TAI - Administración de Empresas</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <style>
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        @keyframes slideInRight { from { opacity: 0; transform: translateX(30px); } to { opacity: 1; transform: translateX(0); } }
        @keyframes slideInBottom { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes zoomIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }
        
        .animate-in { 
            animation-duration: 0.5s; 
            animation-fill-mode: forwards; 
        }
        .fade-in { animation-name: fadeIn; }
        .slide-in-from-right { animation-name: slideInRight; }
        .slide-in-from-bottom { animation-name: slideInBottom; }
        .zoom-in { animation-name: zoomIn; }

        /* Clase para ocultar pasos inactivos */
        .step-hidden {
            display: none !important;
        }
    </style>
</head>
<body class="min-h-screen bg-gray-50 flex flex-col font-sans text-gray-800">

    <!-- Header -->
    <header class="bg-white border-b shadow-sm py-4 px-6 md:px-12 flex justify-between items-center z-10">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Cálculo de Tasa TAI</h1>
            <p class="text-sm text-gray-500">Administración de Empresas 2025-2</p>
        </div>
        <div id="step-indicator" class="bg-blue-100 text-blue-800 px-4 py-2 rounded-lg font-semibold text-sm">
            Paso 1 de 6
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-1 flex flex-col justify-center items-center p-6 md:p-12 overflow-hidden relative">
        <div class="w-full max-w-5xl mx-auto flex flex-col h-full min-h-[500px]">
            
            <!-- Step Header -->
            <div class="text-center mb-10">
                <h2 id="step-title" class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-2">Título</h2>
                <p id="step-subtitle" class="text-lg text-gray-500">Subtítulo</p>
            </div>

            <!-- Contenedor dinámico de pasos -->
            <div class="flex-1 flex items-center justify-center relative w-full">
                
                <!-- PASO 0: Introducción -->
                <div id="slide-0" class="step-content flex flex-col items-center justify-center space-y-8 animate-in fade-in zoom-in w-full">
                    <p class="text-xl text-gray-700 text-center max-w-2xl">
                        La <strong>Tasa de Ausencia Intersemestral (TAI)</strong> mide la proporción de estudiantes que, debiendo continuar con sus estudios, no renuevan su matrícula para el siguiente periodo.
                    </p>
                    <div class="bg-blue-50 border-2 border-blue-200 rounded-xl p-8 shadow-sm">
                        <h3 class="text-lg font-bold text-blue-800 mb-4 text-center">Fórmula General</h3>
                        <div class="flex items-center text-3xl font-serif text-gray-800">
                            <span>TAI<sub>t</sub></span>
                            <span class="mx-4">=</span>
                            <div class="flex flex-col items-center">
                                <span class="border-b-2 border-gray-800 px-4 pb-1">Ausentes<sub>t</sub></span>
                                <span class="px-4 pt-1">Matriculados<sub>t-1</sub></span>
                            </div>
                            <span class="mx-4">×</span>
                            <span>100</span>
                        </div>
                    </div>
                    <p class="text-gray-500 italic text-sm text-center max-w-lg mt-4">
                        A continuación, desglosaremos esta fórmula paso a paso usando los datos reales del programa de Administración de Empresas.
                    </p>
                </div>

                <!-- PASO 1: Población Base -->
                <div id="slide-1" class="step-content step-hidden flex flex-col items-center justify-center space-y-6 animate-in slide-in-from-right w-full">
                    <div class="bg-blue-600 text-white p-8 rounded-full shadow-lg flex flex-col items-center justify-center w-64 h-64 border-4 border-blue-200">
                        <i data-lucide="users" class="w-16 h-16 mb-2"></i>
                        <span class="text-5xl font-bold">601</span>
                        <span class="text-sm mt-2 text-blue-100 text-center">Estudiantes Matriculados<br/>en 2025-1</span>
                    </div>
                    <p class="text-xl text-gray-700 text-center max-w-xl">
                        Este es nuestro denominador en la fórmula (<strong>Matriculados<sub>t-1</sub></strong>). Representa el total de estudiantes inscritos en el semestre inmediatamente anterior.
                    </p>
                </div>

                <!-- PASO 2: Ausentes Brutos -->
                <div id="slide-2" class="step-content step-hidden flex flex-col items-center justify-center w-full animate-in slide-in-from-right">
                    <div class="flex flex-col md:flex-row items-center justify-center space-y-6 md:space-y-0 md:space-x-12 w-full">
                        <!-- Base -->
                        <div class="flex flex-col items-center">
                            <div class="bg-blue-100 p-4 rounded-xl shadow border border-blue-300 w-40 h-40 flex flex-col items-center justify-center">
                                <span class="text-3xl font-bold text-blue-800">601</span>
                                <span class="text-xs text-center mt-1 text-blue-600">Matriculados 2025-1</span>
                            </div>
                        </div>
                        
                        <i data-lucide="arrow-right" class="w-8 h-8 text-gray-400 rotate-90 md:rotate-0"></i>
                        
                        <div class="flex flex-col space-y-4">
                            <!-- Continuaron -->
                            <div class="bg-green-100 p-4 rounded-xl shadow border border-green-300 w-56 flex items-center space-x-3">
                                <i data-lucide="check-circle" class="w-7 h-7 text-green-600 flex-shrink-0"></i>
                                <div>
                                    <span class="block text-2xl font-bold text-green-800">458</span>
                                    <span class="text-xs text-green-700 leading-tight">Continuaron en 2025-2</span>
                                </div>
                            </div>
                            <!-- Ausentes iniciales -->
                            <div class="bg-orange-100 p-4 rounded-xl shadow border border-orange-300 w-56 flex items-center space-x-3">
                                <i data-lucide="user-minus" class="w-7 h-7 text-orange-600 flex-shrink-0"></i>
                                <div>
                                    <span class="block text-2xl font-bold text-orange-800">143</span>
                                    <span class="text-xs text-orange-700 leading-tight">No están en 2025-2</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="mt-8 bg-gray-50 p-4 rounded-lg border border-gray-200 text-center max-w-xl">
                        <p class="text-lg text-gray-700">
                            La diferencia inicial es de <strong class="text-orange-600">143 estudiantes</strong> (601 - 458). <br/>¿Pero son todos estos estudiantes desertores o ausentes reales? <strong>No.</strong>
                        </p>
                    </div>
                </div>

                <!-- PASO 3: Clasificación -->
                <div id="slide-3" class="step-content step-hidden flex flex-col items-center justify-center w-full animate-in zoom-in">
                    <div class="bg-orange-100 px-6 py-3 rounded-full mb-6 border border-orange-300 shadow-sm flex items-center gap-2">
                        <span class="text-2xl font-bold text-orange-800">143</span>
                        <span class="text-orange-700 font-medium">Ausentes iniciales a clasificar</span>
                    </div>
                    
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-4xl">
                        <!-- Terminaron académicamente -->
                        <div class="bg-white p-6 rounded-xl shadow-md border-t-4 border-blue-400 flex flex-col items-center text-center">
                            <i data-lucide="check-circle" class="w-8 h-8 text-blue-500 mb-2"></i>
                            <span class="text-3xl font-bold text-gray-800">9</span>
                            <span class="text-sm font-medium text-gray-600 mt-2">Terminaron Académicamente</span>
                            <p class="text-xs text-gray-500 mt-2">Salida justificada.</p>
                        </div>
                        
                        <!-- Graduados -->
                        <div class="bg-white p-6 rounded-xl shadow-md border-t-4 border-green-400 flex flex-col items-center text-center">
                            <i data-lucide="graduation-cap" class="w-8 h-8 text-green-500 mb-2"></i>
                            <span class="text-3xl font-bold text-gray-800">108</span>
                            <span class="text-sm font-medium text-gray-600 mt-2">Graduados</span>
                            <p class="text-xs text-gray-500 mt-2">Salida por culminación exitosa.</p>
                        </div>
                        
                        <!-- No renovaron -->
                        <div class="bg-red-50 p-6 rounded-xl shadow-lg border-2 border-red-400 flex flex-col items-center text-center transform scale-105">
                            <i data-lucide="x-circle" class="w-8 h-8 text-red-500 mb-2"></i>
                            <span class="text-4xl font-bold text-red-600">26</span>
                            <span class="text-sm font-bold text-red-800 mt-2">No renovaron matrícula</span>
                            <p class="text-xs text-red-600 mt-2">Este es el grupo que nos interesa para la Tasa TAI.</p>
                        </div>
                    </div>
                    
                    <p class="mt-6 text-gray-600 italic">
                        9 + 108 + 26 = 143 estudiantes.
                    </p>
                </div>

                <!-- PASO 4: Variables Finales -->
                <div id="slide-4" class="step-content step-hidden flex flex-col items-center justify-center space-y-8 animate-in slide-in-from-bottom w-full">
                    <div class="flex flex-col md:flex-row items-center justify-center gap-8 w-full max-w-3xl">
                        
                        <div class="flex-1 bg-red-50 rounded-xl p-6 border-2 border-red-200 text-center relative w-full shadow-md">
                            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-red-600 text-white text-xs px-3 py-1 rounded-full font-bold shadow whitespace-nowrap">
                                Numerador (Ausentes<sub>t</sub>)
                            </div>
                            <span class="block text-6xl font-bold text-red-600 mt-2">26</span>
                            <span class="block text-sm text-red-800 mt-2 font-medium">Estudiantes que no renovaron</span>
                        </div>

                        <div class="flex-1 bg-blue-50 rounded-xl p-6 border-2 border-blue-200 text-center relative w-full shadow-md">
                            <div class="absolute -top-4 left-1/2 transform -translate-x-1/2 bg-blue-600 text-white text-xs px-3 py-1 rounded-full font-bold shadow whitespace-nowrap">
                                Denominador (Matriculados<sub>t-1</sub>)
                            </div>
                            <span class="block text-6xl font-bold text-blue-600 mt-2">601</span>
                            <span class="block text-sm text-blue-800 mt-2 font-medium">Estudiantes base inicial</span>
                        </div>

                    </div>
                    
                    <p class="text-xl text-gray-700 text-center max-w-2xl">
                        Solo tomamos los <strong>26</strong> estudiantes como "Ausentes" reales para el cálculo, ya que los graduados y los que terminaron académicamente cumplieron su ciclo normativo.
                    </p>
                </div>

                <!-- PASO 5: Cálculo Final -->
                <div id="slide-5" class="step-content step-hidden flex flex-col items-center justify-center space-y-10 animate-in zoom-in w-full">
                    <div class="bg-white border-2 border-gray-200 rounded-2xl p-8 shadow-xl">
                        <div class="flex items-center text-4xl font-serif text-gray-800">
                            <span class="font-bold text-blue-900">TAI</span>
                            <span class="mx-4">=</span>
                            <div class="flex flex-col items-center">
                                <span class="border-b-4 border-gray-800 px-6 pb-2 text-red-600 font-bold">26</span>
                                <span class="px-6 pt-2 text-blue-600 font-bold">601</span>
                            </div>
                            <span class="mx-4">×</span>
                            <span class="font-bold">100</span>
                        </div>
                    </div>

                    <i data-lucide="arrow-down" class="w-8 h-8 text-gray-400"></i>

                    <div class="bg-green-600 text-white rounded-2xl p-6 shadow-2xl flex items-center space-x-6 transform scale-110">
                        <i data-lucide="calculator" class="w-12 h-12 text-green-200"></i>
                        <div>
                            <span class="block text-sm text-green-100 uppercase tracking-wider font-semibold mb-1">Resultado Final TAI</span>
                            <span class="block text-6xl font-bold">4.3%</span>
                        </div>
                    </div>

                    <p class="text-gray-600 text-center max-w-lg font-medium">
                        Esto significa que el <strong>4.3%</strong> de la población estudiantil esperada para continuar en Administración de Empresas decidió no renovar su matrícula para el periodo 2025-2.
                    </p>
                </div>

            </div>

        </div>
    </main>

    <!-- Footer Controls -->
    <footer class="bg-white border-t p-6">
        <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between items-center gap-4">
            
            <!-- Progress Bar -->
            <div id="progress-bar-container" class="flex space-x-2 w-full md:w-auto order-2 md:order-1 justify-center">
                <!-- Se inyecta por JS -->
            </div>

            <!-- Buttons -->
            <div class="flex space-x-4 w-full md:w-auto order-1 md:order-2">
                <button
                    id="btn-prev"
                    class="flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-blue-600"
                >
                    Anterior
                </button>
                <button
                    id="btn-next"
                    class="flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-blue-600 text-white hover:bg-blue-700 shadow-md"
                >
                    Siguiente
                </button>
            </div>
        </div>
    </footer>

    <!-- Logica JavaScript -->
    <script>
        // Inicializar Iconos
        lucide.createIcons();

        // Estado
        let currentStep = 0;
        
        // Datos de la presentación
        const stepsData = [
            { title: "Introducción: Cálculo de la Tasa TAI", subtitle: "Periodo 2025-2 | Programa: Administración de Empresas" },
            { title: "Paso 1: Población Base", subtitle: "Identificamos los estudiantes del periodo anterior (t-1)" },
            { title: "Paso 2: Diferencia Inicial (Ausentes Brutos)", subtitle: "¿Cuántos de estos 601 estudiantes NO continuaron?" },
            { title: "Paso 3: Clasificación de Ausentes", subtitle: "Depurando los 143 estudiantes que no están en 2025-2" },
            { title: "Paso 4: Variables Finales", subtitle: "Identificando los componentes de la fórmula" },
            { title: "Paso 5: Cálculo Final", subtitle: "Aplicando la fórmula para obtener la TAI" }
        ];

        const totalSteps = stepsData.length;

        // Referencias al DOM
        const titleEl = document.getElementById('step-title');
        const subtitleEl = document.getElementById('step-subtitle');
        const indicatorEl = document.getElementById('step-indicator');
        const progressContainer = document.getElementById('progress-bar-container');
        const btnPrev = document.getElementById('btn-prev');
        const btnNext = document.getElementById('btn-next');

        function renderProgress() {
            progressContainer.innerHTML = '';
            for (let i = 0; i < totalSteps; i++) {
                const dot = document.createElement('div');
                dot.className = `h-2 rounded-full transition-all duration-300 ${
                    i === currentStep ? 'bg-blue-600 w-12' : 
                    i < currentStep ? 'bg-blue-300 w-8' : 'bg-gray-200 w-8'
                }`;
                progressContainer.appendChild(dot);
            }
        }

        function updateUI() {
            // Actualizar Textos
            titleEl.innerText = stepsData[currentStep].title;
            subtitleEl.innerText = stepsData[currentStep].subtitle;
            indicatorEl.innerText = `Paso ${currentStep + 1} de ${totalSteps}`;

            // Actualizar Diapositivas (Ocultar/Mostrar para re-disparar animación)
            for (let i = 0; i < totalSteps; i++) {
                const slide = document.getElementById(`slide-${i}`);
                if (i === currentStep) {
                    slide.classList.remove('step-hidden');
                    // Pequeño truco para reiniciar la animación CSS
                    slide.style.animation = 'none';
                    slide.offsetHeight; /* trigger reflow */
                    slide.style.animation = null; 
                } else {
                    slide.classList.add('step-hidden');
                }
            }

            // Actualizar Botones
            if (currentStep === 0) {
                btnPrev.disabled = true;
                btnPrev.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-gray-100 text-gray-400 cursor-not-allowed";
            } else {
                btnPrev.disabled = false;
                btnPrev.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-white border border-gray-300 text-gray-700 hover:bg-gray-50 hover:text-blue-600 cursor-pointer";
            }

            if (currentStep === totalSteps - 1) {
                btnNext.disabled = true;
                btnNext.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-gray-100 text-gray-400 cursor-not-allowed";
                btnNext.innerText = "Siguiente";
            } else {
                btnNext.disabled = false;
                btnNext.className = "flex-1 md:flex-none px-6 py-3 rounded-lg font-semibold flex items-center justify-center transition-colors bg-blue-600 text-white hover:bg-blue-700 shadow-md cursor-pointer";
                btnNext.innerText = currentStep === totalSteps - 2 ? "Ver Resultado Final" : "Siguiente";
            }

            renderProgress();
        }

        // Event Listeners
        btnNext.addEventListener('click', () => {
            if (currentStep < totalSteps - 1) {
                currentStep++;
                updateUI();
            }
        });

        btnPrev.addEventListener('click', () => {
            if (currentStep > 0) {
                currentStep--;
                updateUI();
            }
        });

        // Inicialización de la vista
        updateUI();

    </script>
</body>
</html>
